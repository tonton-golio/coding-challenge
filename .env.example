# Secret used to sign the session cookie (HMAC-SHA256). Use a long random string
# (>= 16 chars). REQUIRED in production — the app refuses to run without it.
SESSION_SECRET=replace-with-a-long-random-string

# Comma-separated list of admin emails (case-insensitive).
ADMIN_EMAILS=you@example.com

# Setup token (a reusable shared secret) required to create an ADMIN account, so
# nobody can self-register as an admin just by knowing an admin email. Admins
# paste it into the "Admin setup" field on the signup page. Use a long random
# string, keep it secret, and rotate it once your admin accounts exist.
ADMIN_SETUP_TOKEN=replace-with-a-long-random-token

# Leave the two below UNSET for local dev (uses a JSON file store). REQUIRED in
# production on Vercel — the JSON store is not durable on serverless.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) -------------------------------------------------------
# Used to send candidate verification + invite emails. Leave RESEND_API_KEY
# UNSET for local dev: the app runs in "log mode" (no email is sent; verify
# links are logged to the server console and surfaced in the signup response).
# REQUIRED in production — signup fails closed on Vercel without it.
RESEND_API_KEY=
# From address. Must be on a domain you've verified in Resend to email external
# candidates. The default onboarding sender only delivers to your own address.
EMAIL_FROM=Simply.tv Hiring <onboarding@resend.dev>
# Public base URL used to build links in emails (e.g. https://your-app.vercel.app).
# On Vercel this falls back to VERCEL_PROJECT_PRODUCTION_URL if unset.
APP_URL=
